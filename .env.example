# Telegram Bot Credentials (secrets - do not commit to git)
TG_BOT_TOKEN=your_telegram_bot_token
TG_CHAT_ID=your_telegram_chat_id

# Monitor Settings
CHECK_INTERVAL=3h

# URLs are configured in urls_config.yaml (can be committed to git)

# Backup notification via Discord webhook (free, reliable on iOS)
# 1. Create a Discord server (or use existing)
# 2. Server Settings > Integrations > Webhooks > New Webhook
# 3. Copy the webhook URL and paste below
# 4. Enable notifications for that channel on your phone
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/tbd

# OCI ARM Instance Launcher credentials
# Get these from your Oracle Cloud Infrastructure console
COMPARTMENT_ID="ocid1.tenancy.oc1..xxx"
SUBNET_ID="ocid1.subnet.oc1.us-sanjose-1.xxx"
IMAGE_ID="ocid1.image.oc1.us-sanjose-1l.xxx"
AD_NAME="xxxx:US-SANJOSE-1-AD-1"
DISPLAY_NAME="sj-ARM-Free"
SSH_AUTHORIZED_KEYS="ssh-rsa A***"
